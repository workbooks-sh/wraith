{
  "name": "fallow",
  "version": "2.77.0",
  "description": "Codebase intelligence for TypeScript and JavaScript. Finds unused code, duplication, circular dependencies, complexity hotspots, and architecture drift. Optional runtime intelligence layer (Fallow Runtime) adds production execution evidence. Rust-native, sub-second, 95 framework plugins.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fallow-rs/fallow.git"
  },
  "homepage": "https://docs.fallow.tools",
  "bugs": {
    "url": "https://github.com/fallow-rs/fallow/issues"
  },
  "intent": {
    "version": 1,
    "repo": "fallow-rs/fallow",
    "docs": "https://docs.fallow.tools"
  },
  "keywords": [
    "unused-code",
    "circular-dependencies",
    "code-duplication",
    "lint",
    "analyzer",
    "typescript",
    "javascript",
    "static-analysis",
    "agent-skills",
    "tanstack-intent"
  ],
  "engines": {
    "node": ">=16"
  },
  "bin": {
    "fallow": "bin/fallow",
    "fallow-lsp": "bin/fallow-lsp",
    "fallow-mcp": "bin/fallow-mcp"
  },
  "exports": {
    "./types": {
      "types": "./types/output-contract.d.ts"
    },
    "./package.json": "./package.json",
    "./bin/*": "./bin/*",
    "./scripts/*": "./scripts/*",
    "./skills/*": "./skills/*",
    "./schema.json": "./schema.json"
  },
  "typesVersions": {
    "*": {
      "types": [
        "./types/output-contract.d.ts"
      ]
    }
  },
  "files": [
    "bin",
    "scripts",
    "skills",
    "!skills/_artifacts",
    "types",
    "README.md",
    "schema.json"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test:platform": "node --test scripts/platform-package.test.js",
    "test:verify": "node --test scripts/verify-binary.test.js"
  },
  "dependencies": {
    "detect-libc": "2.1.2"
  },
  "devDependencies": {
    "@tanstack/intent": "0.0.41"
  },
  "optionalDependencies": {
    "@fallow-cli/darwin-arm64": "2.77.0",
    "@fallow-cli/darwin-x64": "2.77.0",
    "@fallow-cli/linux-x64-gnu": "2.77.0",
    "@fallow-cli/linux-arm64-gnu": "2.77.0",
    "@fallow-cli/linux-x64-musl": "2.77.0",
    "@fallow-cli/linux-arm64-musl": "2.77.0",
    "@fallow-cli/win32-arm64-msvc": "2.77.0",
    "@fallow-cli/win32-x64-msvc": "2.77.0"
  }
}
